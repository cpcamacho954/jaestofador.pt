---
interface Props {
  title: string;
  description: string;
  lang: 'pt' | 'en';
  ogTitle: string;
  ogDescription: string;
  ogLocale: string;
  altLangHref: string;
  altLang: 'pt' | 'en';
}

const { title, description, lang, ogTitle, ogDescription, ogLocale, altLangHref, altLang } = Astro.props;
---
<!DOCTYPE html>
<html lang={lang} dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#2C1F14">

  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={ogDescription}>
  <meta property="og:image" content="/images/space_zandria-chair-5727263_1280.jpg">
  <meta property="og:type" content="website">
  <meta property="og:locale" content={ogLocale}>

  <link rel="alternate" hreflang={altLang} href={altLangHref}>
  <link rel="alternate" hreflang={lang} href={lang === 'pt' ? '/' : '/en/'}>

  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,600&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/reset.css';
  @import '../styles/variables.css';
  @import '../styles/typography.css';
  @import '../styles/layout.css';
  @import '../styles/components.css';
  @import '../styles/animations.css';
  @import '../styles/nav.css';
  @import '../styles/hero.css';
  @import '../styles/about.css';
  @import '../styles/services.css';
  @import '../styles/portfolio.css';
  @import '../styles/contact.css';
  @import '../styles/footer.css';
</style>
