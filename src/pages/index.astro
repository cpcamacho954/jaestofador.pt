---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Jaestofador — Estofaria e Decoração de Interiores">

  <header id="site-header" role="banner">
    <nav id="main-nav" aria-label="Navegação principal">
      <a href="#" class="nav-logo" aria-label="Jaestofador — Início">
        <img src="/images/jaestofador_logo.png" alt="Jaestofador" class="logo-img">
      </a>

      <button class="nav-toggle"
              aria-expanded="false"
              aria-controls="nav-menu"
              aria-label="Abrir menu de navegação">
        <span class="burger-bar" aria-hidden="true"></span>
        <span class="burger-bar" aria-hidden="true"></span>
        <span class="burger-bar" aria-hidden="true"></span>
      </button>

      <ul id="nav-menu" class="nav-links" role="list">
        <li><a href="#sobre">Sobre Nós</a></li>
        <li><a href="#servicos">Serviços</a></li>
        <li><a href="#portfolio">Portfólio</a></li>
        <li><a href="#contacto" class="nav-cta">Pedir Orçamento</a></li>
      </ul>
    </nav>
  </header>

  <main id="main-content">

    <!-- HERO -->
    <section id="hero" aria-label="Secção principal">
      <div class="hero-media" aria-hidden="true">
        <video class="hero-video" autoplay muted loop playsinline preload="metadata">
          <source src="/videos/259050_small.mp4" type="video/mp4">
        </video>
        <div class="hero-overlay"></div>
      </div>

      <div class="hero-content">
        <p class="hero-eyebrow">Artesanato Português</p>
        <h1 class="hero-headline">
          Espaços que<br>
          <em>contam histórias</em>
        </h1>
        <p class="hero-subheadline">
          Estofaria e decoração de interiores feita à mão,<br class="break-lg">
          com materiais selecionados e amor pelo detalhe.
        </p>
        <div class="hero-actions">
          <a href="#portfolio" class="btn btn-primary">Ver Portfólio</a>
          <a href="#contacto" class="btn btn-ghost">Pedir Orçamento</a>
        </div>
      </div>

      <div class="hero-scroll-hint" aria-hidden="true">
        <span class="scroll-label">Deslizar</span>
        <span class="scroll-line"></span>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="sobre" aria-labelledby="sobre-heading">
      <div class="about-grid">
        <div class="about-image-wrap">
          <figure class="about-figure reveal-left">
            <img class="about-img"
                 src="/images/23555986-real-estate-9053405_1280.jpg"
                 alt="Sala de estar com estofaria artesanal em tons quentes"
                 width="1280"
                 height="854"
                 loading="lazy">
          </figure>
          <div class="about-badge reveal-scale" style="--delay: 300ms">
            <span class="badge-number">20+</span>
            <span class="badge-label">Anos de<br>Experiência</span>
          </div>
        </div>

        <div class="about-text reveal-right">
          <span class="section-eyebrow">Sobre Nós</span>
          <h2 id="sobre-heading">Tradição artesanal,<br>elegância contemporânea</h2>
          <p class="about-lead">
            Somos uma oficina familiar portuguesa, fundada na convicção de que um espaço bem
            decorado transforma a vida de quem o habita.
          </p>
          <p>
            Cada peça que criamos é tratada como uma obra única. Utilizamos tecidos, couros
            e madeiras criteriosamente selecionados de fornecedores nacionais e europeus,
            garantindo durabilidade, beleza e sustentabilidade em cada projeto.
          </p>

          <ul class="about-values" role="list">
            <li class="about-value-item">
              <span class="value-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M6 3h12l4 6-10 13L2 9z"/>
                  <path d="M2 9h20M6 3l-4 6m16-6 4 6"/>
                </svg>
              </span>
              <div class="value-body">
                <strong>Materiais Premium</strong>
                <p>Tecidos e couros de origem certificada, selecionados pela sua qualidade e durabilidade.</p>
              </div>
            </li>
            <li class="about-value-item">
              <span class="value-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M3 7h18v10H3z"/>
                  <path d="M7 7v3m4-3v5m4-5v3"/>
                </svg>
              </span>
              <div class="value-body">
                <strong>Feito à Medida</strong>
                <p>Cada projeto começa por ouvir o cliente. Desenhamos soluções únicas para cada espaço.</p>
              </div>
            </li>
            <li class="about-value-item">
              <span class="value-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 22c0 0-8-5.5-8-12a8 8 0 0 1 16 0c0 6.5-8 12-8 12z"/>
                  <path d="M12 22V10"/>
                </svg>
              </span>
              <div class="value-body">
                <strong>Produção Local</strong>
                <p>Priorizamos fornecedores nacionais e práticas sustentáveis, apoiando a economia portuguesa.</p>
              </div>
            </li>
          </ul>

          <a href="#contacto" class="btn btn-primary">Fale Connosco</a>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="servicos" aria-labelledby="servicos-heading">
      <div class="services-inner">
        <div class="section-header reveal-up">
          <span class="section-eyebrow">O Que Fazemos</span>
          <h2 id="servicos-heading">Os Nossos Serviços</h2>
          <p class="section-intro">
            Da conceção ao acabamento final, oferecemos um serviço completo de
            estofaria e decoração de interiores.
          </p>
        </div>

        <div class="services-grid">
          <article class="service-card reveal-up" style="--delay: 0ms">
            <div class="service-img-wrap">
              <img src="/images/leemelina08-home-1622401_1280.jpg"
                   alt="Sala de estar decorada com estofaria artesanal"
                   loading="lazy" width="1280" height="854">
            </div>
            <div class="service-body">
              <span class="service-num" aria-hidden="true">01</span>
              <h3>Estofaria de Interiores</h3>
              <p>
                Sofás, cadeiras, poltronas e painéis estofados, produzidos com precisão
                artesanal e materiais de excelência que resistem ao tempo.
              </p>
              <a href="#contacto" class="link-arrow">Saber Mais</a>
            </div>
          </article>

          <article class="service-card reveal-up" style="--delay: 120ms">
            <div class="service-img-wrap">
              <img src="/images/mxh6789-bedding-4321545_1280.jpg"
                   alt="Quarto decorado com têxteis artesanais"
                   loading="lazy" width="1280" height="854">
            </div>
            <div class="service-body">
              <span class="service-num" aria-hidden="true">02</span>
              <h3>Decoração de Quartos</h3>
              <p>
                Projetos completos para quartos — cabeceiras, colchas, cortinas e almofadas
                em harmonia perfeita, criando ambientes de descanso únicos.
              </p>
              <a href="#contacto" class="link-arrow">Saber Mais</a>
            </div>
          </article>

          <article class="service-card reveal-up" style="--delay: 240ms">
            <div class="service-img-wrap">
              <img src="/images/kaboompics-pillows-791906_1280.jpg"
                   alt="Almofadas artesanais em tecido premium"
                   loading="lazy" width="1280" height="854">
            </div>
            <div class="service-body">
              <span class="service-num" aria-hidden="true">03</span>
              <h3>Projetos Personalizados</h3>
              <p>
                Trabalhamos diretamente consigo para criar peças exclusivas que reflitam
                a sua personalidade, estilo de vida e necessidades específicas.
              </p>
              <a href="#contacto" class="link-arrow">Saber Mais</a>
            </div>
          </article>

          <article class="service-card reveal-up" style="--delay: 360ms">
            <div class="service-img-wrap">
              <img src="/images/stocksnap-bedroom-2593500_1280.jpg"
                   alt="Peça de mobiliário restaurada com cuidado artesanal"
                   loading="lazy" width="1280" height="854">
            </div>
            <div class="service-body">
              <span class="service-num" aria-hidden="true">04</span>
              <h3>Restauro de Peças</h3>
              <p>
                Devolvemos vida a móveis antigos e de família, preservando a sua história
                e memória com técnicas artesanais tradicionais e materiais de qualidade.
              </p>
              <a href="#contacto" class="link-arrow">Saber Mais</a>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- PORTFOLIO -->
    <section id="portfolio" aria-labelledby="portfolio-heading">
      <div class="section-header reveal-up">
        <span class="section-eyebrow">Os Nossos Trabalhos</span>
        <h2 id="portfolio-heading">Portfólio</h2>
        <p class="section-intro">
          Uma seleção das peças e projetos que nos enchem de orgulho.
        </p>
      </div>

      <div class="portfolio-grid" role="list">
        <figure class="portfolio-item portfolio-item--large reveal-fade" role="listitem">
          <img src="/images/space_zandria-chair-5727263_1280.jpg"
               alt="Cadeira de design estofada à mão com tecido premium"
               loading="lazy" width="1280" height="854">
          <figcaption class="portfolio-caption">
            <span class="portfolio-cat">Estofaria</span>
            <strong class="portfolio-title">Cadeira Signature</strong>
          </figcaption>
        </figure>

        <figure class="portfolio-item reveal-fade" role="listitem" style="--delay: 120ms">
          <img src="/images/kaboompics-pillows-791906_1280.jpg"
               alt="Coleção de almofadas artesanais em tecidos naturais"
               loading="lazy" width="1280" height="854">
          <figcaption class="portfolio-caption">
            <span class="portfolio-cat">Têxteis</span>
            <strong class="portfolio-title">Coleção de Almofadas</strong>
          </figcaption>
        </figure>

        <figure class="portfolio-item reveal-fade" role="listitem" style="--delay: 240ms">
          <img src="/images/stocksnap-bedroom-2593500_1280.jpg"
               alt="Quarto completo decorado com estofaria artesanal"
               loading="lazy" width="1280" height="854">
          <figcaption class="portfolio-caption">
            <span class="portfolio-cat">Quartos</span>
            <strong class="portfolio-title">Suite Completa</strong>
          </figcaption>
        </figure>

        <figure class="portfolio-item reveal-fade" role="listitem" style="--delay: 360ms">
          <img src="/images/mxh6789-bedding-4321545_1280.jpg"
               alt="Roupa de cama artesanal em algodão de alta qualidade"
               loading="lazy" width="1280" height="854">
          <figcaption class="portfolio-caption">
            <span class="portfolio-cat">Têxteis</span>
            <strong class="portfolio-title">Roupa de Cama Premium</strong>
          </figcaption>
        </figure>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contacto" aria-labelledby="contacto-heading">
      <div class="contact-inner">
        <div class="contact-info reveal-left">
          <span class="section-eyebrow">Fale Connosco</span>
          <h2 id="contacto-heading">Peça o seu<br>Orçamento</h2>
          <p>
            Estamos prontos para transformar o seu espaço. Partilhe
            connosco a sua visão e entraremos em contacto em 24 horas.
          </p>
          <address class="contact-details">
            <div class="contact-detail-item">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.49 2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6.18 6.18l.91-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <a href="tel:+351912345678">+351 912 345 678</a>
            </div>
            <div class="contact-detail-item">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <a href="mailto:geral@jaestofador.pt">geral@jaestofador.pt</a>
            </div>
            <div class="contact-detail-item">
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Lisboa, Portugal</span>
            </div>
          </address>
        </div>

        <div class="contact-form-wrap reveal-right">
          <h3>Envie-nos uma mensagem</h3>

          <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" aria-label="Formulário de pedido de orçamento">
            <input type="hidden" name="access_key" value="YOUR_W3FORMS_ACCESS_KEY">
            <input type="hidden" name="subject" value="Novo pedido de orçamento - Jaestofador">
            <input type="hidden" name="from_name" value="Jaestofador Website">
            <input type="checkbox" name="botcheck" class="hidden" style="display:none">

            <div class="form-row">
              <div class="field-group">
                <input type="text" id="nome" name="nome" required autocomplete="name" placeholder=" ">
                <label for="nome">Nome Completo</label>
                <span class="field-error" role="alert" aria-live="polite"></span>
              </div>
              <div class="field-group">
                <input type="email" id="email" name="email" required autocomplete="email" placeholder=" ">
                <label for="email">Endereço de Email</label>
                <span class="field-error" role="alert" aria-live="polite"></span>
              </div>
            </div>

            <div class="form-row">
              <div class="field-group">
                <input type="tel" id="telefone" name="telefone" autocomplete="tel" placeholder=" ">
                <label for="telefone">Telefone (opcional)</label>
                <span class="field-error" role="alert" aria-live="polite"></span>
              </div>
              <div class="field-group">
                <select id="servico" name="servico" required>
                  <option value="" disabled selected></option>
                  <option value="estofaria">Estofaria de Interiores</option>
                  <option value="quartos">Decoração de Quartos</option>
                  <option value="personalizado">Projeto Personalizado</option>
                  <option value="restauro">Restauro de Peças</option>
                  <option value="outro">Outro</option>
                </select>
                <label for="servico">Tipo de Serviço</label>
                <span class="field-error" role="alert" aria-live="polite"></span>
              </div>
            </div>

            <div class="field-group field-group--full">
              <textarea id="mensagem" name="mensagem" rows="5" required placeholder=" "></textarea>
              <label for="mensagem">Descreva o seu projeto</label>
              <span class="field-error" role="alert" aria-live="polite"></span>
            </div>

            <input type="hidden" name="redirect" value="">

            <div class="btn-submit-wrap">
              <button type="submit" class="btn btn-primary btn-submit">
                <span class="btn-text">Enviar Pedido</span>
                <span class="btn-spinner" aria-hidden="true"></span>
              </button>
            </div>

            <p class="form-success" role="status" aria-live="polite">
              Mensagem enviada com sucesso!<br>
              Entraremos em contacto consigo em breve.
            </p>
          </form>
        </div>
      </div>
    </section>

  </main>

  <footer id="site-footer" role="contentinfo">
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/images/jaestofador_logo.png" alt="Jaestofador" class="logo-img">
        <p>Artesanato de interiores com alma portuguesa. Cada peça, uma história.</p>
      </div>

      <nav class="footer-nav" aria-label="Navegação de rodapé">
        <span class="footer-nav-heading">Navegação</span>
        <a href="#sobre">Sobre Nós</a>
        <a href="#servicos">Serviços</a>
        <a href="#portfolio">Portfólio</a>
        <a href="#contacto">Contacto</a>
      </nav>

      <div class="footer-contact">
        <span class="footer-contact-heading">Contacto</span>
        <a href="tel:+351912345678">+351 912 345 678</a>
        <a href="mailto:geral@jaestofador.pt">geral@jaestofador.pt</a>
        <p>Lisboa, Portugal</p>
      </div>
    </div>

    <div class="footer-legal">
      <p>&copy; {new Date().getFullYear()} Jaestofador. Todos os direitos reservados.</p>
      <a href="#">Política de Privacidade</a>
    </div>
  </footer>

  <script>
    document.body.classList.add('js-ready');

    // Nav
    const header = document.getElementById('site-header');
    const toggle = document.querySelector('.nav-toggle');
    const navMenu = document.getElementById('nav-menu');
    const navLinks = navMenu?.querySelectorAll('a') ?? [];
    const sections = document.querySelectorAll('section[id]');

    function openNav() {
      document.body.classList.add('nav-open');
      toggle?.setAttribute('aria-expanded', 'true');
      toggle?.setAttribute('aria-label', 'Fechar menu');
      navMenu?.querySelector('a')?.focus();
    }

    function closeNav() {
      document.body.classList.remove('nav-open');
      toggle?.setAttribute('aria-expanded', 'false');
      toggle?.setAttribute('aria-label', 'Abrir menu de navegação');
    }

    toggle?.addEventListener('click', () => {
      document.body.classList.contains('nav-open') ? closeNav() : openNav();
    });

    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (document.body.classList.contains('nav-open')) closeNav();
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && document.body.classList.contains('nav-open')) {
        closeNav();
        toggle?.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (
        document.body.classList.contains('nav-open') &&
        !navMenu?.contains(e.target as Node) &&
        !toggle?.contains(e.target as Node)
      ) closeNav();
    });

    // Scroll-aware header
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:1px;left:0;width:1px;height:1px;pointer-events:none;';
    document.body.prepend(sentinel);

    if ('IntersectionObserver' in window) {
      new IntersectionObserver((entries) => {
        header?.classList.toggle('header--scrolled', !entries[0].isIntersecting);
      }, { threshold: 0 }).observe(sentinel);

      const sectionObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const id = entry.target.id;
          navLinks.forEach((link) => {
            link.classList.toggle('nav-link--active', link.getAttribute('href') === '#' + id);
          });
        });
      }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });

      sections.forEach((s) => sectionObserver.observe(s));
    }

    // Scroll Reveal
    if ('IntersectionObserver' in window) {
      const revealElements = document.querySelectorAll(
        '.reveal-up, .reveal-left, .reveal-right, .reveal-fade, .reveal-scale'
      );
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          revealObserver.unobserve(entry.target);
        });
      }, { threshold: 0, rootMargin: '0px' });
      revealElements.forEach((el) => revealObserver.observe(el));
    } else {
      document.querySelectorAll('.reveal-up,.reveal-left,.reveal-right,.reveal-fade,.reveal-scale')
        .forEach((el) => el.classList.add('is-visible'));
    }

    // Parallax
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReducedMotion) {
      const heroContent = document.querySelector('.hero-content') as HTMLElement | null;
      const aboutFigure = document.querySelector('.about-figure') as HTMLElement | null;

      if (heroContent || aboutFigure) {
        let rafId: number | null = null;

        function applyParallax() {
          const scrollY = window.scrollY;
          if (heroContent) {
            const heroEl = document.getElementById('hero');
            const heroH = heroEl ? heroEl.offsetHeight : window.innerHeight;
            if (scrollY < heroH) {
              heroContent.style.transform = 'translateY(' + (scrollY * 0.3) + 'px)';
            }
          }
          if (aboutFigure) {
            const aboutEl = document.getElementById('sobre');
            if (aboutEl) {
              const rect = aboutEl.getBoundingClientRect();
              const sectH = aboutEl.offsetHeight;
              const progress = Math.min(Math.max(1 - (rect.top + sectH) / (window.innerHeight + sectH), 0), 1);
              const offset = (progress - 0.5) * 60;
              aboutFigure.style.transform = 'translateY(' + offset + 'px)';
            }
          }
          rafId = null;
        }

        window.addEventListener('scroll', () => {
          if (!rafId) rafId = requestAnimationFrame(applyParallax);
        }, { passive: true });
        applyParallax();
      }
    }

    // Smooth scroll
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', (e) => {
        const href = anchor.getAttribute('href');
        const target = href && href !== '#' ? document.querySelector(href) : null;
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.pushState(null, '', href);
      });
    });

    // W3Forms submission
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = form?.querySelector('.btn-submit') as HTMLButtonElement | null;
    const successMsg = form?.querySelector('.form-success') as HTMLElement | null;

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        // Client-side validation
        const fields = [
          { el: form.querySelector('#nome') as HTMLInputElement, msg: 'Por favor, introduza o seu nome.' },
          { el: form.querySelector('#email') as HTMLInputElement, msg: 'Por favor, introduza o seu email.' },
          { el: form.querySelector('#servico') as HTMLSelectElement, msg: 'Por favor, selecione um tipo de serviço.' },
          { el: form.querySelector('#mensagem') as HTMLTextAreaElement, msg: 'Por favor, descreva o seu projeto.' },
        ];

        let hasErrors = false;
        fields.forEach(({ el, msg }) => {
          const group = el?.closest('.field-group');
          const errorEl = group?.querySelector('.field-error');
          if (el && !el.value.trim()) {
            group?.classList.add('has-error');
            group?.classList.remove('is-valid');
            if (errorEl) errorEl.textContent = msg;
            hasErrors = true;
          } else {
            group?.classList.remove('has-error');
            group?.classList.add('is-valid');
            if (errorEl) errorEl.textContent = '';
          }
        });

        if (hasErrors) return;

        if (submitBtn) {
          submitBtn.classList.add('is-loading');
          submitBtn.disabled = true;
        }

        try {
          const formData = new FormData(form);
          const response = await fetch(form.action, {
            method: 'POST',
            body: formData,
          });

          if (response.ok) {
            if (successMsg) {
              successMsg.classList.add('is-visible');
              successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
            form.reset();
            form.querySelectorAll('.field-group').forEach((g) => {
              g.classList.remove('has-error', 'is-valid');
              const err = g.querySelector('.field-error');
              if (err) err.textContent = '';
            });
            setTimeout(() => {
              if (successMsg) successMsg.classList.remove('is-visible');
            }, 8000);
          }
        } catch {
          // silently fail
        } finally {
          if (submitBtn) {
            submitBtn.classList.remove('is-loading');
            submitBtn.disabled = false;
          }
        }
      });
    }
  </script>

</Layout>
