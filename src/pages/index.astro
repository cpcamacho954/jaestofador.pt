---
import Layout from '../layouts/Layout.astro';
import Site from '../components/Site.astro';
import { translations } from '../i18n';

const t = translations.pt;
---
<Layout
  title={t.pageTitle}
  description={t.metaDescription}
  lang="pt"
  ogTitle={t.ogTitle}
  ogDescription={t.ogDescription}
  ogLocale={t.ogLocale}
  altLangHref="/en/"
  altLang="en"
>
  <Site lang="pt" t={t} />
</Layout>
