---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Jaestofador — Estofaria e decoração de interiores artesanal portuguesa. Criamos espaços únicos com materiais premium e técnicas tradicionais." } = Astro.props;
---
<!DOCTYPE html>
<html lang="pt" dir="ltr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="theme-color" content="#2C1F14">

  <meta property="og:title" content="Jaestofador — Estofaria Artesanal">
  <meta property="og:description" content="Estofaria e decoração de interiores feita à mão em Portugal.">
  <meta property="og:image" content="/images/space_zandria-chair-5727263_1280.jpg">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="pt_PT">

  <title>{title}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,600&display=swap" rel="stylesheet">
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  @import '../styles/reset.css';
  @import '../styles/variables.css';
  @import '../styles/typography.css';
  @import '../styles/layout.css';
  @import '../styles/components.css';
  @import '../styles/animations.css';
  @import '../styles/nav.css';
  @import '../styles/hero.css';
  @import '../styles/about.css';
  @import '../styles/services.css';
  @import '../styles/portfolio.css';
  @import '../styles/contact.css';
  @import '../styles/footer.css';
</style>
